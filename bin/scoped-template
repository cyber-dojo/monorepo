#!/usr/bin/env python3
"""Compose the monorepo-co-deployment flow template, scoped to this commit.

The `monorepo-co-deployment` flow does NOT re-run any service's SDLC controls.
Those live in each service's own flow (`monorepo-a`, `monorepo-b`, ...), defined
in `source/<name>/kosli.yml` and opened by that service's reusable workflow. This
flow records ONLY the co-deployment set: which component artifacts were built and
cleared their own gate on this commit.

So the generated template is just one bare artifact entry per CHANGED component:

    version: 1
    trail:
      artifacts:
        - name: A
        - name: B

There are deliberately NO trail-level attestations (e.g. pull-request now lives
in each service's own flow) and NO per-artifact attestations here. A service
attests its artifact to this trail (`kosli attest artifact --name A --flow ...`)
only AFTER passing its own self-check, so the mere presence of the artifact is
the evidence. An in-scope component that was expected but never attested shows up
as MISSING and drags the trail non-compliant, which is exactly what the gate
(`kosli evaluate trail`) keys on. So the trail's compliance covers exactly what
this commit should have built -- never more, and (crucially) never less.

The artifact names are the component names passed in; they match the `--name`
each service attests with. Each named component must have a
`source/<name>/kosli.yml` (the same file `bin/gen-filters` and the `scope` job
key on); a name without one is a typo or drift and fails loud here rather than
silently dropping the component from the co-deployment set.

Usage:
  bin/scoped-template '["A","B"]'
  bin/scoped-template --repo-root . '["A","B"]'

Options:
  -h, --help       Show this help and exit.
  --repo-root DIR  Repo root containing source/ (default: current dir).

Example:
  bin/scoped-template '["A","B"]' > scoped-template.yml
"""
import argparse
import json
import sys
from pathlib import Path

import yaml


def require_component(repo_root, component):
    """Fail loud unless the named component has a source/<name>/kosli.yml."""
    path = repo_root / "source" / component / "kosli.yml"
    if not path.is_file():
        raise SystemExit(f"no such component {component!r}: {path} not found")


def compose(repo_root, components):
    """Return the co-deployment template: one bare artifact per component."""
    artifacts = []
    for component in components:
        require_component(repo_root, component)
        artifacts.append({"name": component})
    return {"version": 1, "trail": {"artifacts": artifacts}}


def parse_args(argv):
    """Parse command-line arguments and return the populated namespace."""
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--repo-root",
        default=".",
        help="Repo root containing source/ (default: current dir).",
    )
    parser.add_argument(
        "changed",
        help='JSON array of changed component names, e.g. \'["A","B"]\'.',
    )
    return parser.parse_args(argv)


def main(argv):
    """Entry point: compose the co-deployment template and write YAML to stdout."""
    args = parse_args(argv)
    components = json.loads(args.changed)
    template = compose(Path(args.repo_root), components)
    yaml.safe_dump(template, sys.stdout, sort_keys=False)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
